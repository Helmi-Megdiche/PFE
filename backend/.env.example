NODE_ENV=development
PORT=3000
# Docker (npm run db:up) uses port 5433 to avoid conflict with local PostgreSQL 18
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/pfe_parental_control
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ISSUER=pfe-parental-control
LOG_LEVEL=info
# Minutes before another risky-content mission can be generated (dev default 2, prod 15)
MISSION_RISK_COOLDOWN_MINUTES=2
