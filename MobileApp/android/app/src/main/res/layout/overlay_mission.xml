<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/overlay_mission_card"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/overlay_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/overlay_mission_badge"
            android:textColor="#FBBF24"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlay_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlay_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="4dp"
            android:textColor="#CBD5E1"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/overlay_points"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#94A3B8"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/overlay_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"
            android:text="@string/overlay_mission_warning"
            android:textColor="#F87171"
            android:textSize="13sp" />

        <Button
            android:id="@+id/overlay_btn_complete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="#2563EB"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/overlay_btn_later"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/overlay_mission_later"
            android:textAllCaps="false"
            android:textColor="#94A3B8"
            android:textSize="14sp" />
    </LinearLayout>
</FrameLayout>
